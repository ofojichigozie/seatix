# App
PORT=3000
NODE_ENV=development

# Database (local pgAdmin in dev, Supabase connection string in prod)
DATABASE_URL=postgresql://postgres:password@localhost:5432/seatix

# JWT
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=8h

# Paystack
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Frontend URL (used as Paystack callback base)
CLIENT_URL=http://localhost:5173
